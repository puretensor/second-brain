# Credentials -- never commit actual secret files (credentials.py is code, not secrets)
credentials.json
*credentials*.env
*credentials*.yml
*credentials*.yaml
*credentials*.cfg
*credentials*.conf
*secrets*
*.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Obsidian workspace state (not content)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/
.obsidian/core-plugins.json
.obsidian/hotkeys.json
.obsidian/community-plugins.json

# Obsidian trash
.trash/

# Temp and backup files
*.tmp
*~
*.swp
*.swo
.hot-reload

# Python cache
__pycache__/
*.pyc

# Node modules (if any plugins use them)
node_modules/
