[Unit]
Description=pureMind metrics collector -- system health to PostgreSQL
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=puretensorai
WorkingDirectory=/home/puretensorai/pureMind
Environment=HOME=/home/puretensorai
Environment=PATH=/home/puretensorai/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/python3 /home/puretensorai/pureMind/tools/metrics_collector.py
TimeoutStartSec=180

[Install]
WantedBy=multi-user.target
